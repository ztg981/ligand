# Browser-exposed Supabase configuration.
# These are public client values; authorization is enforced by Supabase Auth,
# RLS, and Edge Function checks.
VITE_SUPABASE_URL="https://your-project-ref.supabase.co"
VITE_SUPABASE_ANON_KEY="your-supabase-publishable-or-anon-key"

# Supabase Edge Function secrets/configuration.
# Set these in the Supabase dashboard or with `supabase secrets set`, not in
# Vercel frontend env vars.
GEMINI_API_KEY="your-google-ai-auth-key"
LIGAND_ALLOWED_ORIGINS="https://your-production-domain.example,https://your-preview-domain.example,http://localhost:5173"

# Private ChatGPT/Codex MCP gateway on Vercel. These values bind the gateway
# to one Supabase OAuth client, one canonical HTTPS resource, and one Ligand
# account. The publishable key is intentionally non-privileged; never add a
# Supabase service-role or secret key to this integration.
SUPABASE_URL="https://your-project-ref.supabase.co"
SUPABASE_PUBLISHABLE_KEY="your-supabase-publishable-key"
LIGAND_MCP_RESOURCE_URL="https://your-production-domain.example/mcp"
LIGAND_MCP_OAUTH_CLIENT_ID="your-pre-registered-supabase-oauth-client-id"
LIGAND_MCP_ALLOWED_USER_ID="00000000-0000-4000-8000-000000000000"
LIGAND_MCP_DOCUMENTATION_URL="https://your-production-domain.example/"
# Enables confirmation-first previews and the single non-destructive apply
# tool. The user must also opt in to each write capability in Ligand.
LIGAND_MCP_ENABLE_TASK_WRITES="false"

# Browser-visible OAuth client identifier used by the consent page. This is a
# public identifier, not a secret, and must match LIGAND_MCP_OAUTH_CLIENT_ID.
VITE_LIGAND_MCP_OAUTH_CLIENT_ID="your-pre-registered-supabase-oauth-client-id"
# Shows the matching capability controls in Ligand. Enable it in the same
# staged deployment as the server flag above.
VITE_LIGAND_MCP_ENABLE_TASK_WRITES="false"
